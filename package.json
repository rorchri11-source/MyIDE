{
  "name": "my-ide",
  "version": "0.1.0",
  "description": "AI-powered desktop IDE with configurable providers",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron electron/main.js",
    "dev": "esbuild src/index.js --bundle --outfile=src/bundle.js --format=iife --platform=browser && npm start",
    "build": "electron-builder",
    "build:renderer": "esbuild src/index.js --bundle --outfile=src/bundle.js --format=iife --platform=browser --minify",
    "test": "node --test src/**/*.test.js"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "codemirror": "^6.0.2",
    "highlight.js": "^11.10.0",
    "marked": "^14.1.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "babel-jest": "^30.3.0",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "ts-jest": "^29.4.9"
  },
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rorchri11-source/MyIDE.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/rorchri11-source/MyIDE/issues"
  },
  "homepage": "https://github.com/rorchri11-source/MyIDE#readme"
}
